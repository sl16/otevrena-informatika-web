---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  showHeader?: boolean;
  showFooter?: boolean;
}

const {
  title = 'Otevřená informatika',
  description = 'Bezplatné výukové materiály a nástroje pro výuku informatiky.',
  image,
  showHeader = true,
  showFooter = true,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, 'https://otevrenainformatika.cz').toString();

const ogImage = image ?? new URL('/og/home.svg', 'https://otevrenainformatika.cz').toString();
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:site_name" content="Otevřená informatika" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-brand-dark text-slate-200">
    {showHeader && <SiteHeader />}
    <slot />
    {showFooter && <SiteFooter />}
  </body>
</html>
