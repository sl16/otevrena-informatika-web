---
import type { Category } from '../lib/types';

interface Props {
  name?: string;
  size?: number;
  className?: string;
  category?: Category;
}

const { name, size = 24, className = '', category } = Astro.props;

const getIcon = () => {
  switch (name) {
    case 'terminal':
      return '💻';
    case 'brain':
      return '🧠';
    case 'cpu':
      return '⚙️';
    case 'shield-lock':
      return '🔒';
    case 'mail-warning':
      return '⚠️';
    case 'mail':
      return '📨';
    case 'circuit-board':
      return '🔌';
    case 'binary':
      return '🔢';
    case 'code':
      return '⌨️';
    case 'zap':
      return '⚡';
    case 'book':
      return '📖';
    case 'database':
      return '🗄️';
    case 'newspaper':
      return '📰';
    case 'smartphone':
      return '📱';
    case 'layout':
      return '🎨';
    case 'more-horizontal':
      return '💬';
    case 'map':
      return '🗺️';
    case 'footprint':
      return '👣';
    case 'television':
      return '📺';
    default:
      return '📄';
  }
};

const getBgColor = () => {
  switch (category) {
    case 'Programování':
      return 'bg-brand-neon/10 text-brand-neon border-brand-neon/20';
    case 'Umělá inteligence':
      return 'bg-brand-cyan/10 text-brand-cyan border-brand-cyan/20';
    case 'Hardware':
      return 'bg-orange-500/10 text-orange-400 border-orange-500/20';
    case 'Kyberbezpečnost':
      return 'bg-red-500/10 text-red-400 border-red-500/20';
    case 'Algoritmizace':
      return 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20';
    case 'Kancelářské aplikace':
      return 'bg-indigo-500/10 text-indigo-400 border-indigo-500/20';
    default:
      return 'bg-white/5 text-slate-400 border-white/10';
  }
};
---

<div
  class={`flex items-center justify-center rounded-3xl border transition-all duration-500 ${getBgColor()} ${className}`}
  style={`font-size: ${size}px;`}
>
  {getIcon()}
</div>
