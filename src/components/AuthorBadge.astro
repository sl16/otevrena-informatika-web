---
interface Props {
  name: string;
  role?: string;
  href?: string;
  date?: string;
}

const { name, role, href, date } = Astro.props;
---

<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
  <div class="flex items-center gap-3">
    <span class="text-lg">👤</span>
    <div>
      <p class="text-[10px] font-mono uppercase tracking-[0.28em] text-slate-500">Autor</p>
      {href ? (
        <a href={href} class="text-sm font-black text-white hover:text-brand-cyan underline underline-offset-4 block">
          {name}
        </a>
      ) : (
        <p class="text-sm font-black text-white">{name}</p>
      )}
      {role && <p class="text-xs text-slate-400">{role}</p>}
    </div>
  </div>
  {date && (
    <div class="flex items-center gap-3">
      <span class="text-lg">🗓️</span>
      <div>
        <p class="text-[10px] font-mono uppercase tracking-[0.28em] text-slate-500">Aktualizováno</p>
        <p class="text-sm font-black text-white">{date}</p>
      </div>
    </div>
  )}
</div>