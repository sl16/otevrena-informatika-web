---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Prose from '../../components/Prose.astro';
import AuthorBadge from '../../components/AuthorBadge.astro';
import { getAuthors } from '../../lib/content';
import { ogImageUrl } from '../../lib/seo';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((entry) => ({
    params: { id: entry.data.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'blog'> };
const post = entry.data;
const { Content } = await entry.render();

const authorHref = post.authorId ? `/autori/${post.authorId}` : undefined;
const authors = await getAuthors();
const author = post.authorId ? authors.find((a) => a.id === post.authorId) : undefined;
---

<BaseLayout
  title={`${post.title} | Blog`}
  description={post.excerpt}
  image={ogImageUrl({ type: 'blog', id: post.id })}
>
  <main class="min-h-screen">
    <section class="py-16">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-xs uppercase tracking-[0.2em] text-slate-500 font-mono mb-3">{post.category}</p>
          <h1 class="text-4xl md:text-5xl font-black text-white tracking-tighter leading-tight">{post.title}</h1>
          <p class="text-slate-300 mt-5 leading-relaxed">{post.excerpt}</p>
        </div>

        <div class="mt-10 rounded-3xl overflow-hidden border border-white/5 bg-black/20">
          <img
            src={post.imageUrl}
            alt={post.title}
            class="w-full aspect-[16/7] object-cover"
            referrerpolicy="no-referrer"
            loading="lazy"
          />
        </div>

        <div class="mt-10">
          <AuthorBadge
            name={author?.name ?? post.author}
            role={author?.role}
            href={authorHref}
            date={post.date}
          />
        </div>

        <div class="mt-12 rounded-3xl border border-white/5 bg-brand-card/50 p-8">
          <Prose>
            <article>
              <Content />
            </article>
          </Prose>
        </div>

        <div class="mt-12">
          <a
            href="/blog"
            class="bg-white/5 hover:bg-white/10 text-white px-6 py-4 rounded-xl font-bold transition-colors border border-white/10 inline-flex items-center justify-center gap-2"
          >
            ⬅️ Zpět na blog
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
