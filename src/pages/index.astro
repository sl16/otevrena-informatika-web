---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
import { getApps, getBlogPosts, getMaterials } from '../lib/content';
import { ogImageUrl } from '../lib/seo';

const materials = await getMaterials();
const apps = await getApps();
const blogPosts = await getBlogPosts();

const latestMaterials = materials.slice(0, 3);
const latestApps = apps.slice(0, 3);
const latestBlogPosts = blogPosts.slice(0, 3);
---

<BaseLayout
  title="Otevřená informatika"
  description="Bezplatné vzdělávací materiály a aplikace pro výuku informatiky na ZŠ i SŠ."
  image={ogImageUrl({ type: 'home' })}
>
  <div class="bg-brand-dark">
    <section class="relative py-32 overflow-hidden">
      <div class="absolute inset-0 opacity-20 pointer-events-none">
        <div
          class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[600px] bg-brand-neon/20 blur-[120px] rounded-full"
        />
      </div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center max-w-4xl mx-auto">
          <h1 class="text-5xl md:text-7xl font-black text-white mb-8 leading-[0.9] tracking-tighter">
            Bezplatné <span class="text-brand-cyan">vzdělávací materiály</span> pro informatiku
          </h1>
          <p class="text-xl text-slate-400 mb-12 leading-relaxed max-w-2xl mx-auto">
            Sdílím pedagogické materiály a vyvíjím vzdělávací aplikace, které učitelům usnadňují výuku moderních
            technologií.
          </p>
          <ul class="mb-10 flex flex-wrap md:flex-nowrap justify-center gap-3 text-sm">
            <li
              class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-white/10 bg-white/5 text-slate-200 whitespace-nowrap"
            >
              <span aria-hidden="true">🫰</span>
              <span>Zcela zdarma</span>
            </li>
            <li
              class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-white/10 bg-white/5 text-slate-200 whitespace-nowrap"
            >
              <span aria-hidden="true">🎯</span>
              <span>Interaktivní projektová výuka</span>
            </li>
            <li
              class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-white/10 bg-white/5 text-slate-200 whitespace-nowrap"
            >
              <span aria-hidden="true">👩‍🏫</span>
              <span>Od učitele pro učitele</span>
            </li>
            <li
              class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-white/10 bg-white/5 text-slate-200 whitespace-nowrap"
            >
              <span aria-hidden="true">🔓</span>
              <span>Open-source</span>
            </li>
          </ul>
          <div class="flex flex-col sm:flex-row gap-6 justify-center">
            <a
              href="/materialy"
              class="bg-brand-neon hover:bg-white text-brand-dark px-10 py-5 rounded-xl font-black transition-all shadow-[0_0_40px_rgba(0,102,255,0.3)] flex items-center justify-center gap-2 text-lg"
            >
              ✨ Procházet materiály
            </a>
            <a
              href="/tematicke-plany"
              class="bg-white/5 hover:bg-white/10 text-white px-10 py-5 rounded-xl font-bold transition-all backdrop-blur-sm flex items-center justify-center gap-2 border border-white/10 text-lg"
            >
              🗺️ Tematické plány
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-black/20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between mb-16">
          <div>
            <h2 class="text-4xl font-black text-white">Nejnovější materiály</h2>
          </div>
          <a
            href="/materialy"
            class="text-brand-cyan font-bold hover:text-brand-neon transition-colors flex items-center gap-2 group text-sm uppercase tracking-widest"
          >
            Všechny materiály <span class="group-hover:translate-x-1 transition-transform">➡️</span>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
          {latestMaterials.map((mat) => (
            <Card
              href={`/materialy/${mat.id}`}
              iconName={mat.iconName}
              title={mat.title}
              description={mat.description}
              category={mat.category}
              tags={mat.tags}
              duration={mat.duration}
              targetAudience={mat.targetAudience}
              meta={{ author: mat.authorName ?? mat.author, date: mat.dateCz }}
            />
          ))}
        </div>
      </div>
    </section>

    <section class="py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between mb-16">
          <div>
            <h2 class="text-4xl font-black text-white">Vzdělávací aplikace</h2>
          </div>
          <a
            href="/aplikace"
            class="text-brand-cyan font-bold hover:text-brand-neon transition-colors flex items-center gap-2 group text-sm uppercase tracking-widest"
          >
            Všechny aplikace <span class="group-hover:translate-x-1 transition-transform">➡️</span>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
          {latestApps.map((app) => (
            <Card
              href={`/aplikace/${app.id}`}
              iconName={app.iconName}
              title={app.name}
              description={app.description}
              category={app.category}
              meta={app.authorName ? { author: app.authorName } : undefined}
            />
          ))}
        </div>
      </div>
    </section>

    <section class="py-24 bg-black/20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between mb-16">
          <div>
            <h2 class="text-4xl font-black text-white">Z našeho blogu</h2>
          </div>
          <a
            href="/blog"
            class="text-brand-cyan font-bold hover:text-brand-neon transition-colors flex items-center gap-2 group text-sm uppercase tracking-widest"
          >
            Všechny články <span class="group-hover:translate-x-1 transition-transform">➡️</span>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
          {latestBlogPosts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="bg-brand-card/50 backdrop-blur-sm rounded-3xl border border-white/5 overflow-hidden hover:border-brand-neon/30 hover:bg-brand-card transition-all duration-500 group flex flex-col h-full shadow-2xl"
            >
              <div class="aspect-video overflow-hidden">
                <img
                  src={post.imageUrl}
                  alt={post.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  referrerpolicy="no-referrer"
                  loading="lazy"
                />
              </div>
              <div class="p-8 flex flex-col flex-grow">
                <div class="mb-4">
                  <span
                    class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-brand-cyan bg-brand-cyan/10 px-2 py-1 rounded-md border border-brand-cyan/20"
                  >
                    {post.category}
                  </span>
                </div>
                <h3 class="text-xl font-black text-white group-hover:text-brand-cyan transition-colors mb-3 leading-tight">
                  {post.title}
                </h3>
                <p class="text-slate-400 text-sm mb-6 leading-relaxed">{post.excerpt}</p>
                <div class="mt-auto pt-6 border-t border-white/5 flex items-center justify-between">
                  <div class="flex flex-col gap-1">
                    <span class="text-[10px] text-slate-500 flex items-center gap-1.5 font-mono">👤 {post.authorName ?? post.author}</span>
                    <span class="text-[10px] text-slate-500 flex items-center gap-1.5 font-mono">📅 {post.dateCz}</span>
                  </div>
                  <div
                    class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-slate-400 group-hover:bg-brand-neon group-hover:text-brand-dark transition-all duration-300"
                  >
                    ➡️
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
