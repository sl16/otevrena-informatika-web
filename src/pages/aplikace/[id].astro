---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Prose from '../../components/Prose.astro';
import AuthorBadge from '../../components/AuthorBadge.astro';
import IconRenderer from '../../components/IconRenderer.astro';
import { getAuthors } from '../../lib/content';
import { ogImageUrl } from '../../lib/seo';

export async function getStaticPaths() {
  const apps = await getCollection('apps');
  return apps.map((entry) => ({
    params: { id: entry.data.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'apps'> };
const app = entry.data;
const { Content } = await entry.render();

const authors = await getAuthors();
const author = app.authorId ? authors.find((a) => a.id === app.authorId) : undefined;
const authorHref = app.authorId ? `/autori/${app.authorId}` : undefined;
---

<BaseLayout
  title={`${app.name} | Aplikace`}
  description={app.description}
  image={ogImageUrl({ type: 'app', id: app.id })}
>
  <main class="min-h-screen">
    <section class="py-16">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-start gap-6">
          <div class="shrink-0">
            <IconRenderer name={app.iconName} category={app.category} size={44} className="w-20 h-20" />
          </div>
          <div class="flex-1">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500 font-mono mb-3">{app.category}</p>
            <h1 class="text-4xl md:text-5xl font-black text-white tracking-tighter leading-tight">{app.name}</h1>
            <p class="text-slate-300 mt-5 leading-relaxed">{app.description}</p>

            {app.features && app.features.length > 0 && (
              <div class="mt-8 flex flex-wrap gap-2">
                {app.features.map((f: string) => (
                  <span class="inline-flex items-center gap-1 text-[10px] font-mono font-medium text-brand-cyan bg-brand-cyan/10 px-2 py-1 rounded-md border border-brand-cyan/20">
                    {f}
                  </span>
                ))}
              </div>
            )}

            <div class="mt-10 flex flex-col sm:flex-row gap-4">
              <a
                href={app.url}
                class="bg-brand-cyan hover:bg-white text-brand-dark px-6 py-4 rounded-xl font-black transition-colors inline-flex items-center justify-center gap-2"
              >
                ▶️ Spustit aplikaci
              </a>
              <a
                href="/aplikace"
                class="bg-white/5 hover:bg-white/10 text-white px-6 py-4 rounded-xl font-bold transition-colors border border-white/10 inline-flex items-center justify-center gap-2"
              >
                ⬅️ Zpět na aplikace
              </a>
            </div>
          </div>
        </div>

        {app.authorId && (
          <div class="mt-12">
            <AuthorBadge name={author?.name ?? app.authorId} role={author?.role} href={authorHref} />
          </div>
        )}

        <div class="mt-12 rounded-3xl border border-white/5 bg-brand-card/50 p-8">
          <Prose>
            <article>
              <Content />
            </article>
          </Prose>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
