---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import { getApps } from '../../lib/content';
import { ogImageUrl } from '../../lib/seo';

const apps = await getApps();
---

<BaseLayout
  title="Aplikace | Otevřená informatika"
  description="Bezplatné vzdělávací aplikace pro informatiku: simulátory, procvičování a interaktivní aktivity."
  image={ogImageUrl({ type: 'app' })}
>
  <main class="min-h-screen">
    <section class="py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <h1 class="text-4xl md:text-5xl font-black text-white tracking-tighter">Aplikace</h1>
          <p class="text-slate-400 mt-4 leading-relaxed">
            Interaktivní nástroje a simulátory pro výuku moderních témat.
          </p>
        </div>

        <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
          {apps.map((app) => (
            <Card
              href={`/aplikace/${app.id}`}
              iconName={app.iconName}
              title={app.name}
              description={app.description}
              category={app.category}
              tags={app.features}
              meta={app.authorName ? { author: app.authorName } : undefined}
            />
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
